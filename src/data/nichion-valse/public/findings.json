{
  "examines": [
    {
      "title": {
        "en": "Commissioning Authority",
        "ja": "発注権限"
      },
      "body": {
        "en": "Who had authority to request and approve work?",
        "ja": "誰が作業を依頼し、承認する権限を持っていたのか。"
      },
      "status": "OPEN_QUESTION"
    },
    {
      "title": {
        "en": "Scope",
        "ja": "業務範囲"
      },
      "body": {
        "en": "What work was requested, performed or discussed?",
        "ja": "どの作業が依頼、実施又は協議されたのか。"
      },
      "status": "DOCUMENTED"
    },
    {
      "title": {
        "en": "Compensation",
        "ja": "報酬"
      },
      "body": {
        "en": "When and how was payment proposed?",
        "ja": "支払はいつ、どのように提示されたのか。"
      },
      "status": "DISPUTED"
    },
    {
      "title": {
        "en": "Rights",
        "ja": "権利"
      },
      "body": {
        "en": "When were copyright, publishing and master-related matters raised?",
        "ja": "著作権、出版権、原盤関連事項はいつ確認されたのか。"
      },
      "status": "DOCUMENTED"
    },
    {
      "title": {
        "en": "Documentation",
        "ja": "書面"
      },
      "body": {
        "en": "Which written terms were present, absent or unresolved?",
        "ja": "どの書面条件が存在し、不在又は未解決だったのか。"
      },
      "status": "OPEN_QUESTION"
    }
  ],
  "recordSummary": [
    {
      "status": "DOCUMENTED",
      "text": {
        "en": "The available records indicate that a 2021 music commissioning process involved project discussion, creator outreach, rights-related enquiries and coordination before the Reporting Party's scope, compensation and written terms were finalised in the reviewed corpus.",
        "ja": "確認済みの記録は、2021年の音楽制作発注過程において、申告者の業務範囲、報酬及び書面条件が確認済み資料内で確定する前に、企画協議、作家連絡、権利関連の確認及び調整が行われたことを示しています。"
      }
    },
    {
      "status": "DOCUMENTED",
      "text": {
        "en": "The records reviewed show that creator-related coordination, rights questions, demo or project-material handling and payment logistics were active during the project period.",
        "ja": "確認済み資料は、企画期間中に作家関連の調整、権利確認、デモ又は企画資料の取扱い、支払実務が進行していたことを示しています。"
      }
    },
    {
      "status": "OPEN_QUESTION",
      "text": {
        "en": "The available materials do not establish who held final commissioning authority, who approved the project budget or who was responsible for issuing a written order or statement of work.",
        "ja": "確認済み資料では、最終的な発注権限者、企画予算の承認者、発注書又は業務仕様書の発行責任者は確定していません。"
      }
    },
    {
      "status": "OPEN_QUESTION",
      "text": {
        "en": "No final written document has been identified in the reviewed corpus. That absence does not prove no document ever existed outside the reviewed materials.",
        "ja": "確認済み資料内では最終書面は確認されていません。ただし、その不存在は、確認済み資料外に書面が存在しなかったことの証明ではありません。"
      }
    },
    {
      "status": "DISPUTED",
      "text": {
        "en": "The allocation of authority remains an open question, and the record does not make a legal determination about liability, intent or wrongdoing.",
        "ja": "権限分担は未解決の論点であり、本記録は責任、故意又は不正行為について法的判断を行いません。"
      }
    }
  ],
